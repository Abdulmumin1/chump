{
  "name": "chump-agent",
  "version": "0.0.13",
  "private": false,
  "description": "TypeScript CLI for the chump coding assistant",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulmumin1/chump",
    "directory": "client"
  },
  "homepage": "https://github.com/Abdulmumin1/chump#readme",
  "bugs": {
    "url": "https://github.com/Abdulmumin1/chump/issues"
  },
  "bin": {
    "chump": "./dist/chump.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "node src/chump.ts",
    "start": "node src/chump.ts",
    "smoke": "node src/smoke.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run build",
    "build:bin": "bun scripts/build-bin.ts",
    "prepack": "pnpm run build",
    "bin:install": "pnpm link --global",
    "bin:uninstall": "pnpm unlink --global chump-agent"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "chump"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3"
  },
  "changeset": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "onlocal": "^0.5.9"
  }
}
