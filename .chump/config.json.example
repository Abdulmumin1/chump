{
  "provider": "chump_cloud",
  "model": "deepseek-v4-flash",
  "port": 8080,
  "theme": "dark",
  "max_steps": 64,
  "command_timeout": 120,
  "managed_idle_timeout": 30,
  "verbose": true,
  "compaction": {
    "tokens": 200000,
    "keep_recent_tokens": 20000
  },
  "reasoning": {
    "effort": "medium"
  },
  "mcp": {},
  "retry": {
    "max_attempts": 3,
    "initial_delay": 0.5,
    "max_delay": 8.0,
    "backoff": 2.0,
    "jitter": true
  }
}
